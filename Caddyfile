{
  auto_https off
  admin off
}

:{$PORT} {
  root * /srv
  encode zstd gzip

  @assets {
    path /assets/*
    path *.js *.css *.png *.jpg *.jpeg *.svg *.webp *.ico *.woff *.woff2 *.ttf *.map
  }
  header @assets Cache-Control "public, max-age=31536000, immutable"

  @html {
    path /
    path /index.html
  }
  header @html Cache-Control "no-cache, no-store, must-revalidate"

  try_files {path} /index.html
  file_server
}
