# =============================================================================
# Variables de Entorno - Backend API
# =============================================================================
# Copia este archivo a .env y configura los valores según tu entorno.
# Nunca subas el archivo .env al repositorio.

# =============================================================================
# Base de Datos (PostgreSQL)
# =============================================================================
# URL de conexión a PostgreSQL
# Formato: postgresql://usuario:password@host:puerto/nombre_base_datos
DATABASE_URL=postgresql://postgres:password@localhost:5432/web_campo

# =============================================================================
# Redis
# =============================================================================
# URL de conexión a Redis
# Formato: redis://usuario:password@host:puerto
REDIS_URL=redis://localhost:6379
# URL pública de Redis (opcional, para entornos con Redis público)
REDIS_PUBLIC_URL=redis://localhost:6379

# =============================================================================
# JWT (Autenticación)
# =============================================================================
# Secreto para firmar tokens JWT
# Genera un valor seguro con: node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
JWT_SECRET=tu_jwt_secret_aqui_genera_uno_seguro

# =============================================================================
# Cloudinary (Almacenamiento de imágenes)
# =============================================================================
# Nombre de la cuenta de Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
# API Key de Cloudinary
CLOUDINARY_API_KEY=tu_api_key
# API Secret de Cloudinary
CLOUDINARY_API_SECRET=tu_api_secret
# Preset para subir imágenes
CLOUDINARY_PRESET_IMAGENES=campo_imagenes
# Preset para subir documentos
CLOUDINARY_PRESET_DOCS=campo_docs

# =============================================================================
# Servidor
# =============================================================================
# Puerto del servidor (por defecto 3002)
PORT=3002
# Entorno de ejecución: development | production | test
NODE_ENV=development

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Orígenes permitidos separados por coma (opcional)
# Ejemplo: http://localhost:5173,https://tudominio.com
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# Rate Limiting
# =============================================================================
# Ventana de tiempo en milisegundos (por defecto: 900000 = 15 minutos)
RATE_LIMIT_WINDOW_MS=900000
# Número máximo de requests por ventana (por defecto: 100)
RATE_LIMIT_MAX_REQUESTS=100

# =============================================================================
# Logging
# =============================================================================
# Nivel de logging: debug | info | warn | error (por defecto: info)
LOG_LEVEL=info
